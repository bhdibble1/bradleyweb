# Copy to .env and fill in values. .env is for local use only; do not commit secrets.

# --- Database ---
# Local/testing (e.g. Supabase paused): set USE_SQLITE=1 to use SQLite.
#   First time: run "flask db upgrade" to create tables.
# Deploy: set DATABASE_URL (Supabase) and leave USE_SQLITE unset.
USE_SQLITE=1
# DATABASE_URL=

# --- App ---
SECRET_KEY=your-secret-key

# --- Stripe (optional for local; needed for checkout) ---
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PUBLIC_KEY=pk_...

# --- Admin (optional) ---
# ADMIN_EMAIL=your@email.com

# --- Free quit nicotine guide page ---
# GUIDE_BOOK_IMAGE_URL=https://your-image-url.com/book-cover.jpg
# GUIDE_DOWNLOAD_URL=https://your-file-url.com/guide.pdf

# --- Premium memberships (Stripe Product IDs from Dashboard, e.g. prod_xxx) ---
# Each product must have a recurring price; we use the product's default price for checkout.
# STRIPE_PRODUCT_EARLY_BIRD_GOLD=prod_xxx   # $15/mo, 10 spots
# STRIPE_PRODUCT_REGULAR_MEMBER=prod_xxx    # e.g. $5/mo
# STRIPE_PRODUCT_GOLD=prod_xxx              # $100/mo
# PREMIUM_REGULAR_MEMBER_PRICE=5            # display only (e.g. 5 for $5/mo)

# --- Printful (optional; for syncing catalog products to your store) ---
# Get a Private Token from https://developers.printful.com/ (Your tokens).
# PRINTFUL_API_KEY=your_printful_private_token
